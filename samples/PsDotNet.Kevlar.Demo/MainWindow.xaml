<Window x:Class="PsDotNet.Kevlar.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PsDotNet.Kevlar.Demo"
        Title="PsDotNet.Kevlar — Remote Connection"
        Height="680" Width="820"
        MinHeight="600" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- ===== Semantic color tokens ===== -->
        <SolidColorBrush x:Key="Surface"       Color="#23232A" />
        <SolidColorBrush x:Key="SurfaceAlt"    Color="#2B2B33" />
        <SolidColorBrush x:Key="Inset"         Color="#17171B" />
        <SolidColorBrush x:Key="BorderSoft"    Color="#36363F" />
        <SolidColorBrush x:Key="TextPrimary"   Color="#ECECEF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9A9AA6" />
        <SolidColorBrush x:Key="TextMuted"     Color="#63636E" />
        <SolidColorBrush x:Key="Accent"        Color="#31A8FF" />
        <SolidColorBrush x:Key="AccentHover"   Color="#57B8FF" />
        <SolidColorBrush x:Key="AccentPressed" Color="#2491E6" />
        <SolidColorBrush x:Key="Success"       Color="#3FB950" />

        <local:ColorToHexConverter x:Key="ColorToHex" />
        <local:NullToVisibleConverter x:Key="NullToVisible" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Photoshop-style transparency checker, used behind the thumbnail. -->
        <DrawingBrush x:Key="Checker" TileMode="Tile" Viewport="0,0,18,18"
                      ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1C1C20">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,18,18" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#222228">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,9,9" />
                                <RectangleGeometry Rect="9,9,9,9" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- ===== Surfaces ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270"
                                      Opacity="0.30" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Type roles ===== -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,12" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="2,0,0,5" />
        </Style>
        <Style x:Key="Mono" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- ===== Inputs (TextBox / PasswordBox share a look) ===== -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{StaticResource Inset}"
                                BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd" Background="{StaticResource Inset}"
                                BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Buttons ===== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#08233B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource Accent}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAlt}" />
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent"
                                BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAlt}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource TextMuted}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Inset}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderSoft}" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter TargetName="bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color swatch tile -->
        <Style x:Key="Swatch" TargetType="Border">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#55000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270"
                                      Opacity="0.45" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ===== Window background ===== -->
    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1D1D22" Offset="0" />
                <GradientStop Color="#151518" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- header -->
                <RowDefinition Height="Auto" />   <!-- connection bar -->
                <RowDefinition Height="*" />      <!-- main: thumbnail + properties -->
                <RowDefinition Height="Auto" />   <!-- activity log -->
            </Grid.RowDefinitions>

            <!-- ============ HEADER ============ -->
            <Grid Grid.Row="0" Margin="2,0,2,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Wordmark -->
                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="9"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#31A8FF" Offset="0" />
                            <GradientStop Color="#1E6FE0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="K" Foreground="White" FontWeight="Bold" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PsDotNet" Foreground="{StaticResource TextPrimary}"
                                   FontSize="19" FontWeight="SemiBold" />
                        <TextBlock Text=".Kevlar" Foreground="{StaticResource Accent}"
                                   FontSize="19" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Text="Photoshop Remote Connection client"
                               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,1,0,0" />
                </StackPanel>

                <!-- Status pill (offline / connected overlap, toggled by binding) -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Border CornerRadius="12" Padding="11,6" Background="{StaticResource SurfaceAlt}"
                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                            Visibility="{Binding CanConnect, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource TextMuted}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="OFFLINE" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="12" Padding="11,6" Background="#143226"
                            BorderBrush="#1F5E3C" BorderThickness="1"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Success}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="CONNECTED" Foreground="{StaticResource Success}"
                                       FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============ CONNECTION BAR ============ -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Host" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="HostInput" Text="127.0.0.1" Style="{StaticResource DarkTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Password  ·  Photoshop ▸ Edit ▸ Remote Connection"
                                   Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="PasswordInput" Style="{StaticResource DarkPasswordBox}" />
                    </StackPanel>

                    <Button Grid.Column="2" Content="Connect" Click="ConnectButton_Click"
                            Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom"
                            MinWidth="104" IsEnabled="{Binding CanConnect}" />
                    <Button Grid.Column="3" Content="Disconnect" Click="DisconnectButton_Click"
                            Style="{StaticResource GhostButton}" VerticalAlignment="Bottom"
                            Margin="8,0,0,0" MinWidth="100" IsEnabled="{Binding IsConnected}" />
                </Grid>
            </Border>

            <!-- ============ MAIN ============ -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="296" />
                </Grid.ColumnDefinitions>

                <!-- Thumbnail stage -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="DOCUMENT THUMBNAIL"
                                   Style="{StaticResource SectionHeader}" />

                        <!-- Stage with checker backing + empty state -->
                        <Border Grid.Row="1" CornerRadius="8" Background="{StaticResource Checker}"
                                BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                            <Grid>
                                <Image Source="{Binding ThumbnailSource}" Stretch="Uniform"
                                       Margin="14" RenderOptions.BitmapScalingMode="HighQuality" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Visibility="{Binding ThumbnailSource, Converter={StaticResource NullToVisible}}">
                                    <!-- simple framed-image glyph -->
                                    <Path Data="M3,4 L33,4 L33,28 L3,28 Z M3,22 L13,13 L20,19 L26,14 L33,21"
                                          Stroke="{StaticResource TextMuted}" StrokeThickness="2"
                                          StrokeLineJoin="Round" Width="36" Height="32" Stretch="Uniform"
                                          HorizontalAlignment="Center" />
                                    <TextBlock Text="No thumbnail yet" Foreground="{StaticResource TextSecondary}"
                                               FontSize="13" HorizontalAlignment="Center" Margin="0,12,0,0" />
                                    <TextBlock Text="Connect, then Capture the active document"
                                               Foreground="{StaticResource TextMuted}" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button Grid.Row="2" Content="Capture Thumbnail" Click="GetThumbnailButton_Click"
                                Style="{StaticResource GhostButton}" Margin="0,14,0,0"
                                HorizontalAlignment="Left" MinWidth="160"
                                IsEnabled="{Binding IsConnected}" />
                    </Grid>
                </Border>

                <!-- Properties -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PROPERTIES" Style="{StaticResource SectionHeader}" />

                        <!-- Foreground -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource Swatch}"
                                    Background="{Binding ForegroundColor}" />
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Foreground" Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="15" Margin="0,2,0,0"
                                           Text="{Binding ForegroundColor.Color, Converter={StaticResource ColorToHex}}" />
                            </StackPanel>
                        </Grid>

                        <!-- Background -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource Swatch}"
                                    Background="{Binding BackgroundColor}" />
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Background" Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" />
                                <TextBlock Style="{StaticResource Mono}" FontSize="15" Margin="0,2,0,0"
                                           Text="{Binding BackgroundColor.Color, Converter={StaticResource ColorToHex}}" />
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,2,0,14" />

                        <!-- Active tool -->
                        <TextBlock Text="Active Tool" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                        <Border Background="{StaticResource Inset}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0"
                                BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                            <TextBlock Style="{StaticResource Mono}" Text="{Binding CurrentTool}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============ ACTIVITY LOG ============ -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="148" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ACTIVITY LOG" Style="{StaticResource SectionHeader}" Margin="2,0,0,10" />
                    <Border Grid.Row="1" Background="{StaticResource Inset}" CornerRadius="6"
                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                        <TextBox x:Name="LogBox" Text="{Binding StatusText, Mode=OneWay}"
                                 TextChanged="LogBox_TextChanged"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextSecondary}" FontFamily="Consolas"
                                 FontSize="12" Padding="12,10"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
