<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <!--
      Customers consume PsDotNet.Kevlar via NuGet.
      Replace VERSION with the latest from https://www.nuget.org/packages/PsDotNet.Kevlar
    -->
    <PackageReference Include="PsDotNet.Kevlar" Version="2.4.*" />
  </ItemGroup>
</Project>
